# =============================================================================
# .env.example — Corgi Casinos
#
# Copy to `apps/web/.env` (gitignored) and fill in. Everything except the
# NEXT_PUBLIC_ vars is server-only — never prefix a secret with NEXT_PUBLIC_.
# =============================================================================

# ---- CORE -------------------------------------------------------------------
NODE_ENV=development
# Public site origin (used for absolute URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- SUPABASE (Postgres — used as a plain database; NOT Supabase Auth) ------
# Create a project at https://supabase.com, then grab these from
# Project Settings → API. All DB access is server-side, so only the server
# URL + secret key are needed (no browser/publishable key).
SUPABASE_URL=
SUPABASE_SECRET_KEY=sb_secret_...
